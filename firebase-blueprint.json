{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores basic information about the user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "bio": { "type": "string", "description": "A short biography of the user." },
        "avatarUrl": { "type": "string", "format": "uri", "description": "The URL of the user's avatar image." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created." }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    }
  }
}
